DATABASE_URL="postgres://slog:slog@localhost:5432/slog"
DOCKER_DATABASE_URL="postgres://slog:slog@db:5432/slog" # app in compose talks to hostname `db`

POSTGRES_DB="slog"
POSTGRES_USER="slog"
POSTGRES_PASSWORD="slog"
POSTGRES_PORT="5432"

BETTER_AUTH_SECRET="changemepls" # openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000" # url for web app better auth; can be different (but usually isn't)

GITHUB_CLIENT_ID="" # github oauth app; callback e.g. http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_SECRET=""

NEXT_PUBLIC_URL="" # public link, falls back to BETTER_AUTH_URL

# vercel/neon production notes:
# - connect the Vercel Neon integration to this project and expose DATABASE_URL
#   to production + preview.
# - set DATABASE_POOL_MAX="1" for Vercel serverless functions unless/until the
#   app has a dedicated pooling layer.
# - set BETTER_AUTH_URL and NEXT_PUBLIC_URL to the deployed https:// URL.
