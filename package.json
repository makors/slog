{
  "name": "slog",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "bun run --filter @slog/web dev",
    "cli:dev": "bun run --filter @slog/cli dev",
    "build": "bun run --workspaces --if-present build",
    "lint": "bun run --workspaces --if-present lint",
    "test": "bun run --workspaces --if-present test",
    "db:generate": "bun run --filter web db:generate",
    "db:migrate": "bun run --filter web db:migrate",
    "db:push": "bun run --filter web db:push",
    "db:studio": "bun run --filter web db:studio"
  },
  "engines": {
    "bun": ">=1.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/prompts": "^2.4.9"
  },
  "dependencies": {}
}
